<?xml version="1.0" encoding="UTF-8"?>
<!--
  RoomcutAudioEngine을 위한 시스템 LaunchDaemon 설정.

  AudioServerPlugIn은 launchd의 시스템 도메인에서 실행되므로 상대 Mach
  서비스도 같은 도메인에 있어야 한다. 사용자 LaunchAgent는 하위 bootstrap
  도메인이므로 드라이버 프로세스에서 조회할 수 없다.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.roomcut.engine</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ENGINE_BINARY__</string>
    </array>

    <key>MachServices</key>
    <dict>
        <key>com.roomcut.engine</key>
        <true/>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <!--
      KeepAlive를 무조건 true로 두면 활성 상태 보기에서 엔진을 '종료'해도
      launchd가 즉시 되살려 좀비처럼 죽지 않는 것처럼 보인다. SuccessfulExit를
      false로 두면 정상 종료(SIGTERM → return 0: 앱 종료 또는 활성 상태 보기의
      '종료')에는 재시작하지 않고, 크래시(비정상 종료)에는 그대로 재시작해
      docs/05 복구 동작을 유지한다.
    -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ProcessType</key>
    <string>Interactive</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>ROOMCUT_STATE_FILE</key>
        <string>__STATE_FILE__</string>
    </dict>

    <key>StandardOutPath</key>
    <string>__OUT_LOG__</string>
    <key>StandardErrorPath</key>
    <string>__ERR_LOG__</string>
</dict>
</plist>
